# Execution Kernel - Environment Configuration
# Copy to .env and customize for your environment

# ============================================================
# Environment
# ============================================================
NODE_ENV=production
DEBUG=false

# ============================================================
# Database / Persistence
# ============================================================
PERSISTENCE_ENABLED=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kernel_db
DB_USER=kernel
DB_PASSWORD=kernel_change_me_in_production

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_CONSOLE=true
LOG_FILE=true
LOG_DIR=./logs

# ============================================================
# Performance Monitoring
# ============================================================
PERF_MONITORING=true

# ============================================================
# Security & Audit
# ============================================================
AUDIT_ENABLED=true
ENCRYPTION_ENABLED=false

# ============================================================
# API Configuration
# ============================================================
SSE_ENABLED=true
API_PORT=3000
API_HOST=0.0.0.0

# ============================================================
# Cleanup
# ============================================================
CLEANUP_ENABLED=true
CLEANUP_INTERVAL=3600000
CLEANUP_OLDER_THAN_MS=2592000000

# ============================================================
# Advanced Options
# ============================================================
# Max transaction timeout in milliseconds
MAX_TX_TIMEOUT=60000

# Max retries for failed actions
MAX_RETRIES=3

# Enable compensation for failed actions
ENABLE_COMPENSATION=true

# Max active transactions
MAX_ACTIVE_TRANSACTIONS=1000
